@model PMHTest.Models.Employee

@{
    ViewData["Title"] = "Delete";
}

<h1>Удалить</h1>

<div>
    <dl class="row">

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.PhoneNumber)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.PhoneNumber)
        </dd>

        <dt class="col-sm-2">
            Отдел
        </dt>
        <dd class="col-sm-10">
            @Model.Department?.DepartmentName
        </dd>

        <dt class="col-sm-2">
            Фото
        </dt>
        <dd class="col-sm-10">
            @if (string.IsNullOrEmpty(Model.PhotoPath))
            {
                <img src="/img/default-avatar.jpg" width="50" />
            }
            else
            {
                <img src="@Model.PhotoPath" width="50" />
            }
        </dd>

    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Удалить" class="btn btn-danger" />
    </form>

    <div class="mt-3">
        <a asp-action="Index">Обратно к списку</a>
    </div>
</div>